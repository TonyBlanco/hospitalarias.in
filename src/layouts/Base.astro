---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';
import type { Locale, PageId } from '@/data/pages';
import { alternateLinks } from '@/utils/seo';
import { t } from '@/data/i18n';

type Props = {
  title: string;
  description: string;
  locale: Locale;
  pageId: PageId;
};

const { title, description, locale, pageId } = Astro.props;
const canonical = new URL(Astro.url.pathname, 'https://hospitalarias.in').toString();
const alternates = alternateLinks(pageId);
const schema = {
  '@context': 'https://schema.org',
  '@type': 'NGO',
  name: 'Benedict Menni Psycho-Social Rehabilitation Centre',
  url: 'https://hospitalarias.in',
  description,
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="apple-touch-icon" href="/logo.svg" />
    <title>{title} | Hospitalarias</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternates.map((alternate) => <link rel="alternate" hreflang={alternate.lang} href={alternate.href} />)}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Hospitalarias`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://hospitalarias.in/images/2025/09/HOSPITALLER-FAMILY-scaled.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <a class="skip-link" href="#main">{t(locale, 'skipToContent')}</a>
    <Header locale={locale} pageId={pageId} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
