---
import { type Locale, type PageData } from '@/data/pages';

type Props = { page: PageData; locale: Locale };
const { page } = Astro.props;
const isHome = page.id === 'home';
---

{
  isHome ? (
    <section class="hero">
      <div class="container">
        <p class="eyebrow">{page.eyebrow}</p>
        <h1>{page.title}</h1>
        <p>{page.description}</p>
        <div class="hero-actions">
          {page.ctas.map((cta) => <a class:list={['button', cta.variant === 'secondary' && 'secondary']} href={cta.href}>{cta.label}</a>)}
        </div>
      </div>
    </section>
  ) : (
    <section class="section alt">
      <div class="container">
        <p class="eyebrow">{page.eyebrow}</p>
        <h1>{page.title}</h1>
        <p class="lead">{page.description}</p>
      </div>
    </section>
  )
}

<section class="section">
  <div class="container prose">
    {page.sections.map((section) => (
      <article>
        <h2>{section.heading}</h2>
        {section.body.map((paragraph) => <p>{paragraph}</p>)}
        {section.items && <ul>{section.items.map((item) => <li>{item}</li>)}</ul>}
      </article>
    ))}
    {page.ctas.length > 0 && (
      <div class="hero-actions">
        {page.ctas.map((cta) => <a class:list={['button', cta.variant === 'secondary' && 'secondary']} href={cta.href}>{cta.label}</a>)}
      </div>
    )}
  </div>
</section>
